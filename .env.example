# Agent wallet private key (hex, with or without 0x prefix)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Register:     npx @worldcoin/agentkit-cli register <derived-address>
AGENT_PRIVATE_KEY=0xYourPrivateKeyHere

# Server config (server.ts)
PORT=3000
HOST=localhost
BASE_URL=http://localhost:3000

# The address that receives x402 payments when free trial is exhausted
PAY_TO=0xYourPaymentAddressHere

# How many free requests each registered human gets (default: 3)
FREE_TRIAL_USES=3

# Optional: World Chain RPC override (default uses public endpoint)
# WORLD_CHAIN_MAINNET_RPC=https://worldchain-mainnet.g.alchemy.com/public

# Agent demo config (agent.ts)
SERVER_URL=http://localhost:3000
# How many requests the demo sends (should be FREE_TRIAL_USES + 1 to show exhaustion)
DEMO_REQUESTS=4

# World Chain CAIP-2 identifier
WORLD_CHAIN_MAINNET = "eip155:480";

# World USDC on World Chain
USDC_ON_WORLD_CHAIN_MAINNET = "0x79A02482A880bCE3F13e09Da970dC34db4CD24d1";
