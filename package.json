{
  "name": "world-agent-kit-template",
  "version": "0.1.0",
  "description": "World AgentKit integration template — free-trial x402 demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "bun --watch src/server.ts",
    "dev:agent": "bun src/agent.ts",
    "start:server": "bun src/server.ts",
    "register": "bunx @worldcoin/agentkit-cli register",
    "build": "tsc --noEmit"
  },
  "overrides": {
    "@worldcoin/agentkit-core": "0.1.7"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@worldcoin/agentkit": "^0.1.7",
    "hono": "^4.12.14",
    "viem": "^2.48.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.9",
    "typescript": "^5.8.3"
  }
}
